# Copie este arquivo para .env e preencha os valores reais
# NUNCA compartilhe o arquivo .env

# URL do CRM (Railway em produção ou localhost para testes)
CRM_API_URL=https://clinica-crm-production.up.railway.app

# NFS-e SIGISS - AMA (Vieira e Vidigal Martins)
SIGISS_AMA_LOGIN=
SIGISS_AMA_SENHA=

# NFS-e SIGISS - AUXILIUM (Clinica Odontologica Martins)
SIGISS_AUXILIUM_LOGIN=
SIGISS_AUXILIUM_SENHA=

# Pastas destino (ajuste se necessario)
PASTA_AMA=P:\Documentos\NF AMA 2026
PASTA_AUXILIUM=P:\Documentos\NF AUXILIUM 2026
PASTA_MARCOS_PF=P:\Documentos\NF MARCOS VINICIUS PF 2026
